local function bp(tr)
local pos=tr.Position+(-tr.CFrame.LookVector*BD)
return Vector3.new(pos.X,tr.Position.Y,pos.Z)
end
local function freeze(m)
m.Velocity=Vector3.zero
m.AssemblyLinearVelocity=Vector3.zero
m.AssemblyAngularVelocity=Vector3.zero
end
local function snapBehind(m,x)
local gp=bp(x)
m.CFrame=CFrame.lookAt(gp,x.Position)
freeze(m)
cam.CameraType=Enum.CameraType.Scriptable
local camPos=gp+Vector3.new(0,2,0)+(-x.CFrame.LookVector*2)
cam.CFrame=CFrame.lookAt(camPos,x.Position+Vector3.new(0,1,0))
end
local function restoreCam()
cam.CameraType=Enum.CameraType.Custom
end
local function tpBack()
local m=rt(lp)
if m and savedPos then
m.CFrame=savedPos
freeze(m)
end
savedPos=nil
end
