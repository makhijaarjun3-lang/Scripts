local function rainbow(t)
local s=t%1
local r2,g2,b2
if s<1/6 then r2=1 g2=s*6 b2=0
elseif s<2/6 then r2=1-(s-1/6)*6 g2=1 b2=0
elseif s<3/6 then r2=0 g2=1 b2=(s-2/6)*6
elseif s<4/6 then r2=0 g2=1-(s-3/6)*6 b2=1
elseif s<5/6 then r2=(s-4/6)*6 g2=0 b2=1
else r2=1 g2=0 b2=1-(s-5/6)*6 end
return Color3.new(r2,g2,b2)
end
